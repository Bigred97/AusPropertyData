# Copy to `.env` locally — NEVER put real passwords in this file (`.env.example` is often committed).
#   cp .env.example .env
# Then edit `.env` with your real values. `.env` is gitignored.
# Refresh deployment facts: python3 scripts/update_deployment_docs.py

# Postgres — Supabase shows two URIs in the dashboard (Database → Connection string):
#
# 1) Direct (recommended for local dev, asyncpg, ingestion scripts — avoids transaction-pooler quirks)
#    postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
#
# 2) Transaction pooler (port 6543 — good for very high churn / some serverless; user is postgres.PROJECT_REF)
#    postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres
#
# Password must be URL-encoded if it contains # $ @ etc.:
#   python3 -c "import urllib.parse; print(urllib.parse.quote('YOUR_PASSWORD', safe=''))"
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Optional: set to 0 only for a local Postgres without TLS (not Supabase).
# DATABASE_SSL=0

# API
ENV=development
# Include http://127.0.0.1:PORT if you open the app via 127.0.0.1 (different Origin than localhost).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://aussiepropertydata.lovable.app,https://9d387518-e185-4a1e-aecf-4e7c4d6e163b.lovableproject.com

# Ingestion — optional (see docs/AUTOMATION.md). land.vic often 403s scripted GET; use local paths or HTTPS mirrors in CI.
# VPSR_HOUSES_XLS=/path/to/median-house-q2-2025.xls
# VPSR_UNITS_XLS=/path/to/median-unit-q2-2025.xls
# DFFH_RENTAL_XLSX=/path/to/rent.xlsx
# GitHub Actions: set secret DFFH_RENTAL_URL to releases/download/.../dffh-rental-latest.xlsx if dffh.vic stalls on the runner
# DFFH_RENTAL_URL=https://...
# GitHub Actions: set repository secrets VPSR_HOUSES_URL / VPSR_UNITS_URL to raw HTTPS URLs if land.vic blocks the runner.
# VPSR_HOUSES_URL=https://...
# VPSR_UNITS_URL=https://...
